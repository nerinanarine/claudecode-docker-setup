# Claude Code の認証設定
# このファイルを .env にコピーして使用するプラットフォームの設定を記入してください
# .env は Git にコミットしないこと（認証情報が外部に漏れます）

# ============================================================
# 方法 A: AWS Bedrock を使う場合（不要な行は削除または # でコメントアウト）
# ============================================================
CLAUDE_CODE_USE_BEDROCK=1
WS_BEARER_TOKEN_BEDROCK=ここにBedrockのBearerトークンを貼り付け
AWS_REGION=us-east-1

# ============================================================
# 方法 B: Azure AI Foundry を使う場合（不要な行は削除または # でコメントアウト）
# ============================================================
# CLAUDE_CODE_USE_AZURE=1
# ANTHROPIC_BASE_URL=https://<リソース名>.services.ai.azure.com/models
# ANTHROPIC_API_KEY=ここにAzureのAPIキーを貼り付け
